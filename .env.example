# ----- DataCore SANsymphony -----
DCSSVR=192.168.1.10
DCSREST=192.168.1.10
DCSUNAME=Administrator
DCSPWORD=ChangeMe!

# ----- InfluxDB -----
INFLUX_DB=datacore
INFLUX_ADMIN_USER=admin
INFLUX_ADMIN_PASSWORD=changeme-admin
INFLUX_USER=datacore
INFLUX_PASSWORD=changeme

# ----- Grafana -----
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=admin

# ----- Setup UI -----
SETUP_ADMIN_USER=admin
SETUP_ADMIN_PASSWORD=changeme
# Optional: pin the cookie signing key across restarts.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SETUP_SECRET_KEY=

# ----- Collector -----
LOG_LEVEL=INFO
